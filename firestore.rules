rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------
    // HELPERS
    // ---------------------------
    function isUserSignedIn() {
      return request.auth != null;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isRootAdmin() {
      let userDoc = getUserDoc();
      return isUserSignedIn()
             && userDoc.data != null
             && 'roles' in userDoc.data
             && userDoc.data.roles.hasAny(['RootAdmin']);
    }

    function isChurchMember(churchId) {
      let userDoc = getUserDoc();
      return isUserSignedIn()
             && userDoc.data != null
             && 'churchId' in userDoc.data
             && userDoc.data.churchId == churchId;
    }

    function hasChurchRole(churchId, allowedRoles) {
      let userDoc = getUserDoc();
      return isChurchMember(churchId)
             && userDoc.data != null
             && 'roles' in userDoc.data
             && userDoc.data.roles.hasAny(allowedRoles);
    }

    // ---------------------------
    // USERS
    // ---------------------------
    match /users/{uid} {

      // Users can read their own profile
      allow read: if request.auth != null && request.auth.uid == uid;

      // Root Admin full access
      allow read, write: if isRootAdmin();

      // Church Admins can read users in THEIR church
      allow read: if resource.data != null
                  && hasChurchRole(resource.data.churchId, ["Admin"]);

      // Church Admins can create/update users in THEIR church
      allow write: if request.resource.data != null
                   && hasChurchRole(getUserDoc().data.churchId, ["Admin"])
                   && request.resource.data.churchId == getUserDoc().data.churchId;
    }

    // ---------------------------
    // CHURCHES ROOT
    // ---------------------------
    match /churches {
      allow list: if isRootAdmin();
    }

    // ---------------------------------------------------------
    // PUBLIC READ OF CHURCH DOCUMENT ONLY
    // ---------------------------------------------------------
    match /churches/{churchId} {
      allow get: if true;
      allow list: if false;

      // ---------------------------
      // CONTRIBUTIONS SUBCOLLECTION
      // ---------------------------
      match /contributions/{contributionId} {

        // Anyone in the church can read contributions
        allow read: if isChurchMember(churchId);

        // Admins and Finance can create/update/delete contributions
        allow create, update, delete: if
          hasChurchRole(churchId, ["Admin", "Finance"]) ||
          isRootAdmin();
      }

      // ---------------------------------------------------------
      // MEMBERS SUBCOLLECTION
      // ---------------------------------------------------------
      match /members/{memberId} {

        // Reset inherited permissions
        allow read: if false;
        allow list: if false;

        // Root Admin full access
        allow read, write: if isRootAdmin();

        // Church Admins full access
        allow read, write: if hasChurchRole(churchId, ["Admin"]);

        // Members can read their own member document
        allow read: if isChurchMember(churchId)
                     && request.auth.uid == memberId;

        // Public login/check-in queries
        allow list: if request.query.where.size() == 2
                     && request.query.where[0].field == "checkInCode"
                     && request.query.where[1].field == "phoneNumber";

        // Block all writes (except Admins above)
        allow write: if false;
      }

      // All other subcollections under a church
      match /{sub=**} {
        allow read, write: if isRootAdmin();
        allow read: if isChurchMember(churchId);
        allow write: if hasChurchRole(churchId, ["Admin"]);
      }
    }

    // ---------------------------
    // EVENTS (top-level)
    // ---------------------------
    match /events/{eventId} {
      allow read: if isUserSignedIn()
                   && resource.data != null
                   && isChurchMember(resource.data.churchId);

      allow create, update, delete: if isUserSignedIn()
                   && resource.data != null
                   && hasChurchRole(resource.data.churchId, ["Admin"]);

      allow read, write: if isRootAdmin();
    }

    // ---------------------------
    // ROOT ADMIN GLOBAL FALLBACK
    // ---------------------------
    match /{document=**} {
      allow read, write: if isRootAdmin();
    }
  }
}
