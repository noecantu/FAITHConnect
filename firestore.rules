rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // GLOBAL HELPERS
    // ============================================================

    function isUserSignedIn() {
      return request.auth != null;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isRootAdmin() {
      return request.auth.token.roles.hasAny(["RootAdmin"]);
    }

    function isSystemAdmin() {
      return request.auth.token.roles.hasAny(["SystemAdmin"]);
    }

    function isRegionalAdmin() {
      return request.auth.token.roles.hasAny(["RegionalAdmin"]);
    }

    function isSystemUser() {
      return request.auth.token.roles.hasAny([
        "RootAdmin",
        "SystemAdmin",
        "RegionalAdmin"
      ]);
    }

    // ============================================================
    // CHURCH HELPERS
    // ============================================================

    function isChurchMember(churchId) {
      let userDoc = getUserDoc();
      return isUserSignedIn()
        && userDoc.data != null
        && userDoc.data.churchId == churchId;
    }

    function hasChurchRole(churchId, allowedRoles) {
      let userDoc = getUserDoc();
      return isChurchMember(churchId)
        && userDoc.data.roles.hasAny(allowedRoles);
    }

    function isChurchAuditor(churchId) {
      let userDoc = getUserDoc();
      return userDoc.data != null
        && userDoc.data.rolesByChurch != null
        && userDoc.data.rolesByChurch[churchId] != null
        && userDoc.data.rolesByChurch[churchId].hasAny(["ChurchAuditor"]);
    }

    function isGroupManager(churchId) {
      return hasChurchRole(churchId, [
        "Finance",
        "MusicManager",
        "UsherManager",
        "MensGroupManager",
        "WomensGroupManager",
        "YouthGroupManager"
      ]);
    }

    function isGroupMember(churchId) {
      return hasChurchRole(churchId, [
        "MusicMember",
        "Usher",
        "MensGroup",
        "WomensGroup",
        "YouthGroup"
      ]);
    }

    // ============================================================
    // USERS COLLECTION
    // ============================================================

    match /users/{uid} {

      allow read: if request.auth != null && request.auth.uid == uid;

      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data)
           .changedKeys().hasOnly(["profilePhotoUrl"]);

      allow read, write: if isRootAdmin();

      allow read: if resource.data != null
        && hasChurchRole(resource.data.churchId, ["Admin"]);

      allow write: if request.resource.data != null
        && hasChurchRole(getUserDoc().data.churchId, ["Admin"])
        && request.resource.data.churchId == getUserDoc().data.churchId;

      allow read: if isRegionalAdmin();

      allow read: if resource.data != null
        && isChurchAuditor(resource.data.churchId);
    }

    // ============================================================
    // USER SETTINGS SUBCOLLECTION
    // ============================================================

    match /users/{uid}/settings/{settingId} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ============================================================
    // CHURCHES ROOT
    // ============================================================

    match /churches {
      allow list: if isRootAdmin();
    }

    // ============================================================
    // CHURCH DOCUMENT
    // ============================================================

    match /churches/{churchId} {

      allow get: if true;
      allow list: if false;

      allow read: if isRegionalAdmin();

      allow update: if isRegionalAdmin();

      allow read, write: if isChurchMember(churchId);

      allow read: if isChurchAuditor(churchId);

      allow read, write: if isRootAdmin();

      // ---------------------------
      // ATTENDANCE
      // ---------------------------      
      match /attendance/{attendanceId} {

        allow read: if isChurchMember(churchId)
          || hasChurchRole(churchId, ["Admin"])
          || isRootAdmin();

        allow read: if isRegionalAdmin();

        allow write: if hasChurchRole(churchId, ["Admin"]) || isRootAdmin();
      }

      // ---------------------------
      // CONTRIBUTIONS
      // ---------------------------
      match /contributions/{contributionId} {

        allow read: if isChurchMember(churchId)
          || hasChurchRole(churchId, ["Admin", "Finance"])
          || isRootAdmin();

        allow read: if isRegionalAdmin();

        allow create, update, delete: if
          hasChurchRole(churchId, ["Admin", "Finance"]) ||
          isRootAdmin();
      }

      // ---------------------------
      // EVENTS
      // ---------------------------
      match /events/{eventId} {

        allow read: if isChurchMember(churchId)
          || hasChurchRole(churchId, ["Admin"])
          || isGroupManager(churchId)
          || isRootAdmin();

        allow read: if isRegionalAdmin();

        allow create: if
          hasChurchRole(churchId, ["Admin"]) ||
          isGroupManager(churchId) ||
          isRootAdmin();

        allow update: if
          hasChurchRole(churchId, ["Admin"]) ||
          isGroupManager(churchId) ||
          isRootAdmin();

        allow delete: if
          hasChurchRole(churchId, ["Admin"]) ||
          isRootAdmin();

        allow read, write: if isRootAdmin();
      }

      // ---------------------------
      // MEMBERS
      // ---------------------------
      match /members/{memberId} {

        allow read: if false;
        allow list: if false;

        // Root Admin full access
        allow read, write: if isRootAdmin();

        // Church Admin full access
        allow read, write: if hasChurchRole(churchId, ["Admin"]);

        // Regional Admin read-only
        allow read: if isRegionalAdmin();

        // Church Auditor read-only
        allow read: if isChurchAuditor(churchId);

        // Member can read their own record
        allow read: if isChurchMember(churchId)
          && request.auth.uid == memberId;

        // Check-in lookup
        allow list: if request.query.where.size() == 2
          && request.query.where[0].field == "checkInCode"
          && request.query.where[1].field == "phoneNumber";

        allow write: if false;
      }
      
      // ---------------------------
      // REPORTS
      // ---------------------------
      match /reports/{reportId} {

        allow read: if isChurchMember(churchId)
          || hasChurchRole(churchId, ["Admin"])
          || isRootAdmin();

        // Regional Admin read-only
        allow read: if isRegionalAdmin();
        allow write: if hasChurchRole(churchId, ["Admin"]) || isRootAdmin();
      }		
      
      // ---------------------------
      // SERVICE PLANS
      // ---------------------------
      match /servicePlans/{planId} {

        allow read: if isChurchMember(churchId)
          || hasChurchRole(churchId, ["Admin"])
          || isRootAdmin();

        // Regional Admin read-only
        allow read: if isRegionalAdmin();
        allow write: if hasChurchRole(churchId, ["Admin"]) || isRootAdmin();
      }
      
      // ---------------------------
      // SET LISTS
      // ---------------------------
      match /setLists/{setListId} {

        allow read: if isChurchMember(churchId)
          || hasChurchRole(churchId, ["Admin", "MusicManager"])
          || isRootAdmin();

        // Regional Admin read-only
        allow read: if isRegionalAdmin();
        allow write: if hasChurchRole(churchId, ["Admin", "MusicManager"]) || isRootAdmin();
      }	
      
      // ---------------------------
      // SONGS
      // ---------------------------
      match /songs/{songId} {

        allow read: if isChurchMember(churchId)
          || hasChurchRole(churchId, ["Admin", "MusicManager"])
          || isRootAdmin();

        // Regional Admin read-only
        allow read: if isRegionalAdmin();
        allow write: if hasChurchRole(churchId, ["Admin", "MusicManager"]) || isRootAdmin();
      }

      // ---------------------------
      // ALL OTHER SUBCOLLECTIONS
      // ---------------------------
      match /{sub=**} {

        // Root Admin full access
        allow read, write: if isRootAdmin();

        // Church Admin full access
        allow read: if isChurchMember(churchId);
        allow write: if hasChurchRole(churchId, ["Admin"]);

        // Church Auditor read‑only
        allow read: if isChurchAuditor(churchId);

        // Regional Admin read‑only for churches in their region
        allow read: if isRegionalAdmin();
      }
    }

    // ============================================================
    // REGIONS COLLECTION
    // ============================================================

    match /regions/{regionId} {

      // Allow listing regions (needed for Church Admin region selection)
      allow list: if request.auth != null;

      // Allow reading any region (safe: no sensitive data)
      allow read: if request.auth != null;
    }
  }
}